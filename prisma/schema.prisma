generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  password      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  verificationTokens VerificationToken[]
  gtmConnection      GtmConnection?
  mixpanelConnection MixpanelConnection?
  funnels            Funnel[]
  generatedTags      GeneratedTag[]
}

model VerificationToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  type      String   @default("EMAIL_VERIFICATION")
  expires   DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model GtmConnection {
  id                  String    @id @default(cuid())
  userId              String    @unique
  accessToken         String
  refreshToken        String?
  expiresAt           DateTime?
  selectedAccountId   String?
  selectedContainerId String?
  selectedWorkspaceId String?
  connectedAt         DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model MixpanelConnection {
  id                   String   @id @default(cuid())
  userId               String   @unique
  projectToken         String
  serviceAccountUser   String?
  serviceAccountSecret String?
  projectId            String?
  connectedAt          DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Funnel {
  id         String   @id @default(cuid())
  userId     String
  name       String
  websiteUrl String
  steps      String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  generatedTags GeneratedTag[]
}

model GeneratedTag {
  id          String   @id @default(cuid())
  userId      String
  funnelId    String?
  gtmTagId    String?
  name        String
  tagType     String
  triggerName String?
  config      String
  status      String   @default("pending")
  createdAt   DateTime @default(now())

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  funnel Funnel? @relation(fields: [funnelId], references: [id], onDelete: SetNull)
}
